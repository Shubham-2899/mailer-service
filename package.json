{
  "name": "mms-mailer-service",
  "version": "1.0.0",
  "description": "Express-based mailer service for distributed email sending",
  "main": "server.js",
  "scripts": {
    "build": "tsc",
    "start": "node server.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.4.1",
    "nodemailer": "^6.9.13",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.3.1",
    "@types/nodemailer": "^6.4.15",
    "@types/cors": "^2.8.17",
    "typescript": "^5.1.3",
    "ts-node-dev": "^2.0.0"
  }
}
