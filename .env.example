# Mailer Service Environment Variables

# Server Configuration
PORT=4000
NODE_ENV=production

# Mailer Identification
MAILER_ID=vps-1
# Unique identifier for this mailer instance (e.g., vps-1, vps-2, smtp-server-1)

# Authentication Token
# Must match MAILER_AUTH_TOKEN in main backend .env file
MAILER_AUTH_TOKEN=your-secret-token-here
# Generate a strong random token: openssl rand -hex 32

# MongoDB Configuration
# Should be the same MongoDB instance used by main backend
MONGO_URI=mongodb://username:password@host:port/database?authSource=admin

# SMTP Configuration
# These can be set here for fixed SMTP, or passed in request body
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USER=admin@example.com
ROOT_MAIL_USER_PASSWORD=your-smtp-password

# Notes:
# - If SMTP config is not provided in environment, it must be included in the request body
# - MAILER_AUTH_TOKEN must match the token configured in main backend
# - MONGO_URI should point to the same database as main backend
# - MAILER_ID should be unique for each VPS/mailer instance
